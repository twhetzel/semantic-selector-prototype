PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX obo:  <http://purl.obolibrary.org/obo/>

SELECT DISTINCT ?term ?definitionPredicate ?definition ?definitionLang
WHERE {
  VALUES ?termType { owl:Class rdfs:Class skos:Concept }
  ?term rdf:type ?termType .
  VALUES ?definitionPredicate { skos:definition obo:IAO_0000115 }
  ?term ?definitionPredicate ?definition .
  BIND(LANG(?definition) AS ?definitionLang)
}
